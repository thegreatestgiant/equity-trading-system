    {
      "id": 600,
      "type": "row",
      "title": "Cluster Health — Node Counts",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 600 },
      "panels": []
    },
    {
      "id": 601,
      "title": "Postgres Nodes Up",
      "type": "stat",
      "description": "Calculates health percentage: sum(cnpg_collector_up) / 3 expected instances.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 601 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "instant": true,
          "expr": "sum(cnpg_collector_up{cluster=\"trading-db\", job=\"kubernetes-pods\"}) / 3",
          "legendFormat": "Health",
          "refId": "A"
        }
      ]
    },
    {
      "id": 602,
      "title": "Redis Pods Ready",
      "type": "stat",
      "description": "Calculates health percentage: Ready Pods / Expected Replicas (from kube_statefulset_replicas).",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 601 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "instant": true,
          "expr": "sum(kube_pod_status_ready{exported_namespace=\"data\", condition=\"true\", pod=~\"redis-node-.*\"}) / sum(kube_statefulset_replicas{statefulset=\"redis-node\"})",
          "legendFormat": "Health",
          "refId": "A"
        }
      ]
    },
