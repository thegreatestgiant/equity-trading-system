    {
      "id": 605,
      "title": "All Systems Status",
      "type": "stat",
      "description": "1 only when Postgres nodes-up == 3 AND backend/data/frontend namespaces are 100% pod-ready. Any degradation anywhere flips this to 0/red.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 609 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DEGRADED" } } },
            {
              "type": "value",
              "options": { "1": { "text": "ALL SYSTEMS GO" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
